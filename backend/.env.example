# =====================================================
# NPS BACKEND - Environment Variables
# Copy this file to .env and fill in your values
# =====================================================

# Server
NODE_ENV=development
PORT=5000

# PostgreSQL Database (XAMPP uses port 5432 if PostgreSQL is installed separately)
# NOTE: XAMPP ships with MySQL/MariaDB. For this project, install PostgreSQL 15 separately.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nps_db
DB_USER=postgres
DB_PASSWORD=your_postgres_password
DB_SCHEMA=nps

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_min_32_chars
JWT_REFRESH_SECRET=your_refresh_secret_key_also_change_this_32_chars_minimum
JWT_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=7d

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# SMTP (optional for local dev - notifications will just log to console)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=nps@government.mw

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Scheduler - auto payment run day (default 14)
AUTO_RUN_DAY=14
